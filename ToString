public class Main {
    public static void main(String[] args){
       car car1 = new car("ford", "mastung", 2025, "black");
        car car2 = new car("supra", "toyota", 2025, "black");

        System.out.println(car1);
        System.out.println(car2);
    }
}

public class car {

    String make;

    String model;

    int year;

    String color;



    car(String make, String mode,int year, String color){

        this.make = make;

        this.model = mode;

        this.year = year;

        this.color = color;



    }

    @Override

    public String toString(){

        return this.color + " " + this.year + " " + this.make + " " + this.model;

    }

}


